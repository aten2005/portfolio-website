---
import HomeLayout from "../layouts/HomeLayout.astro"

import { getCollection } from "astro:content"
const resume = await getCollection("resume");
const data = resume[0].data;
const education = data.sections["Education"];
const projects = data.sections["Projects"];
const experience = data.sections["Experience"];
---
<HomeLayout title="Resume">
	<div class="text-zinc-400 flex flex-col gap-2 py-4">
		<h1 class="text-3xl text-zinc-300 font-bold">{data.name}</h1>
		<p class="text-zinc-400 text-sm md:text-base">{data.location} | <a href=`mailto:${data.email}`>{data.email}</a> | {data.phone} | <a href=`${data.website}`>aten2005.dev</a> </p>
	</div>
	<div class="flex flex-col gap-4 mb-10">
		<h2>Education</h2>
		{education.map(entry => (
			<div>
				<div class="flex flex-row justify-between">
					<h3 class="text-base md:text-xl">{entry.institution}</h3>
					<p class="text-xs md:text-base align-baseline">{new Date(entry.start_date).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})} - {entry.end_date === "present" ? "Present" : new Date(entry.end_date).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})}</p>
				</div>
					<p class="text-xs md:text-base">{entry.degree} in {entry.area}</p>
			</div>
		))}
	</div>
	<div class="flex flex-col gap-4 text-zinc-400 mb-10">
		<h2>Experience</h2>
		{experience.map(entry => (
			<div>
				<div>
					<div class="flex flex-row justify-between items-center">
						<h3 class="text-base md:text-xl">{entry.position}</h3>
						<p class="text-xs md:text-base align-baseline">{new Date(entry.start_date).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})} - {entry.end_date === "present" ? "Present" : new Date(entry.end_date).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})}</p>
					</div>
					<p class="text-xs md:text-base">{entry.company} • {entry.location}</p>
				</div>
				<ul class="text-xs md:text-sm text-zinc-400">
					{entry.highlights.map(highlight => (
						<li class="flex gap-1.25">
							<span>-</span>
							<span>{highlight}</span>
						</li>
					))}
				</ul>
			</div>
		))}
	</div>
	<div class="flex flex-col gap-4 text-zinc-400 mb-10">
		<h2>Projects</h2>
		{projects.map(entry => (
			<div>
				<div>
					<div class="flex flex-row justify-between">
						<h3 class="text-base md:text-xl">{entry.name}</h3>
						<p class="text-xs md:text-base align-baseline">{new Date(entry.start_date).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})} - {entry.end_date === "present" ? "Present" : new Date(entry.end_date).toLocaleDateString('en-US', {month: 'long', year: 'numeric'})}</p>
					</div>
					<p class="text-xs md:text-base">{entry.description}</p>
				</div>
				<ul class="list-inside list-disc text-xs md:text-sm text-zinc-400">
					{entry.highlights.map(highlight => (
						<li class="flex gap-1.25">
							<span>-</span>
							<span>{highlight}</span>
						</li>
					))}
				</ul>
			</div>
		))}
	</div>
</HomeLayout>